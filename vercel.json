{
  "crons": [
    {
      "path": "/api/daily-stats",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/mobile",
      "destination": "/mobile.html"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/"
    }
  ]
}